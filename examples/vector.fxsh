# Generic vector using comptime type programming

# Create a specialized vector type at compile time
let comptime Vector = fn T -> {
  # Returns a record type structure
  data = T,
  len = 0,
  cap = 0
}

# Specialized vector types
let comptime IntVector = Vector int
let comptime StringVector = Vector string

# Vector operations (simplified)
let vec_new = fn () -> {
  data = [],
  len = 0,
  cap = 0
}

let vec_push = fn vec item ->
  vec

# Usage
let v = vec_new()

42
