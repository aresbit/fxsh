# SQLite CRUD template with parameter binding.
# Run:
#   FXSH_LDFLAGS='-lsqlite3' ./bin/fxsh --native-codegen examples/sqlite_crud_template.fxsh

import Sqlite

let db_slot : unit ptr = Sqlite.slot_alloc (c_ptr_size ())
let _ : unit = c_store_ptr db_slot (c_null ())
let rc_open : int = Sqlite.open_into ":memory:" db_slot
let db : unit ptr = Sqlite.slot_load db_slot
let _ : unit = c_free db_slot

if rc_open != Sqlite.sqlite_ok then
  print "crud template failed: open"
else
  let c_slot : unit ptr = Sqlite.slot_alloc (c_ptr_size ()) in
  let _ : unit = c_store_ptr c_slot (c_null ()) in
  let rc_create_p : int = Sqlite.prepare_into db "create table items(id integer primary key, name text not null)" c_slot in
  let c_stmt : unit ptr = Sqlite.slot_load c_slot in
  let _ : unit = c_free c_slot in
  if rc_create_p != Sqlite.sqlite_ok then
    let _ : int = Sqlite.close_rc db in
    print ("crud template failed: create prepare: " ++ Sqlite.sqlite3_errmsg db)
  else
    let rc_create_s : int = Sqlite.step_rc c_stmt in
    let _ : int = Sqlite.finalize_rc c_stmt in
    if rc_create_s != Sqlite.sqlite_done then
      let _ : int = Sqlite.close_rc db in
      print ("crud template failed: create step: " ++ Sqlite.sqlite3_errmsg db)
    else
      let i_slot : unit ptr = Sqlite.slot_alloc (c_ptr_size ()) in
      let _ : unit = c_store_ptr i_slot (c_null ()) in
      let rc_ins_p : int = Sqlite.prepare_into db "insert into items(id, name) values(?, ?)" i_slot in
      let ins : unit ptr = Sqlite.slot_load i_slot in
      let _ : unit = c_free i_slot in
      if rc_ins_p != Sqlite.sqlite_ok then
        let _ : int = Sqlite.close_rc db in
        print ("crud template failed: insert prepare: " ++ Sqlite.sqlite3_errmsg db)
      else
        let rc_b1 : int = Sqlite.bind_int_rc ins 1 7 in
        let rc_b2 : int = Sqlite.bind_text_rc ins 2 "widget" in
        let rc_ins_s : int = Sqlite.step_rc ins in
        let _ : int = Sqlite.finalize_rc ins in
        if rc_b1 != Sqlite.sqlite_ok or rc_b2 != Sqlite.sqlite_ok or rc_ins_s != Sqlite.sqlite_done then
          let _ : int = Sqlite.close_rc db in
          print ("crud template failed: insert step: " ++ Sqlite.sqlite3_errmsg db)
        else
          let s_slot : unit ptr = Sqlite.slot_alloc (c_ptr_size ()) in
          let _ : unit = c_store_ptr s_slot (c_null ()) in
          let rc_sel_p : int = Sqlite.prepare_into db "select name from items where id = ?" s_slot in
          let sel : unit ptr = Sqlite.slot_load s_slot in
          let _ : unit = c_free s_slot in
          if rc_sel_p != Sqlite.sqlite_ok then
            let _ : int = Sqlite.close_rc db in
            print ("crud template failed: select prepare: " ++ Sqlite.sqlite3_errmsg db)
          else
            let rc_sb : int = Sqlite.bind_int_rc sel 1 7 in
            let rc_sel_s : int = Sqlite.step_rc sel in
            if rc_sb != Sqlite.sqlite_ok or rc_sel_s != Sqlite.sqlite_row then
              let _ : int = Sqlite.finalize_rc sel in
              let _ : int = Sqlite.close_rc db in
              print ("crud template failed: select step: " ++ Sqlite.sqlite3_errmsg db)
            else
              let name : string = Sqlite.sqlite3_column_text sel (int_to_c_int 0) in
              let _ = print ("crud template ok: " ++ name) in
              let _ : int = Sqlite.finalize_rc sel in
              let _ : int = Sqlite.close_rc db in
              print "crud template done"
